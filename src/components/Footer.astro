---
const year = new Date().getFullYear();
---

<footer class="footer">
    <div class="container">
        <div class="footer-main">
            <div class="footer-brand">
                <div class="logo-container">
                    <img src="/StillwareLtd_logo.png" alt="Stillware Ltd" class="logo-img" width="48" height="48" />
                    <span class="logo-text">Stillware Ltd</span>
                </div>
                <p class="tagline">Software you own. Not software you rent.</p>
                <p class="tracking-badge">This site is tracked without cookies or IP logging.</p>
            </div>

            <div class="footer-links">
                <div class="footer-column">
                    <h5>Navigate</h5>
                    <ul class="footer-nav">
                        <li><a href="/">Home</a></li>
                        <li><a href="/apps">Apps</a></li>
                        <li><a href="/manifesto">Manifesto</a></li>
                        <li><a href="/blog">Blog</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h5>Support</h5>
                    <ul class="footer-nav">
                        <li><a href="/support">Help Center</a></li>
                        <li><a href="mailto:support@stillwareltd.com">Email Support</a></li>
                        <li><a href="https://reddit.com/r/ZeroedBudget" target="_blank" rel="noopener">r/ZeroedBudget</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h5>Legal</h5>
                    <ul class="footer-nav">
                        <li><a href="/privacy">Privacy Policy</a></li>
                        <li><a href="/terms">Terms and Conditions</a></li>
                        <li><a href="/delete-account">Delete Account</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Newsletter -->
        <div class="newsletter-section">
            <h4>Join the Rebellion</h4>
            <p>Get notified when we release new buy-once software.</p>
            <form name="newsletter" method="POST" data-netlify="true" action="/success" class="newsletter-form">
                <input type="hidden" name="form-name" value="newsletter" />
                <input type="hidden" name="subject" value="New Newsletter Subscriber" />
                <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
                <button type="submit" class="btn-primary">Subscribe</button>
            </form>
        </div>

        <div class="footer-bottom">
            <p class="copyright">&copy; {year} Stillware Ltd. All rights reserved.</p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--color-secondary);
        color: #ffffff;
        padding: 5rem 0 2rem;
    }

    .footer-main {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 4rem;
        margin-bottom: 3rem;
    }

    .footer-brand {
        max-width: 320px;
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .logo-img {
        height: 48px;
        width: auto;
    }

    .logo-text {
        color: #ffffff;
        font-size: 1.25rem;
        font-weight: 700;
    }

    .tagline {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1rem;
        font-weight: 500;
        margin-top: 0.75rem;
        line-height: 1.5;
    }

    .tracking-badge {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 0.75rem;
        padding: 0.4rem 0.8rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 100px;
        display: inline-block;
    }

    .footer-links {
        display: flex;
        gap: 4rem;
    }

    .footer-column h5 {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 1.25rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .footer-nav {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .footer-nav a {
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        transition: color 0.2s ease;
        font-size: 0.95rem;
    }

    .footer-nav a:hover { color: #ffffff; }

    /* Newsletter */
    .newsletter-section {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding: 2.5rem 0;
        margin-bottom: 2rem;
        text-align: center;
    }

    .newsletter-section h4 {
        color: #ffffff;
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .newsletter-section p {
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 1.25rem;
        font-size: 1rem;
    }

    .newsletter-form {
        display: flex;
        gap: 0.75rem;
        max-width: 480px;
        margin: 0 auto;
    }

    .newsletter-form input[type="email"] {
        flex: 1;
        padding: 0.85rem 1.25rem;
        border-radius: 100px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        font-size: 1rem;
        font-family: var(--font-sans);
        outline: none;
        transition: border-color 0.2s ease;
    }

    .newsletter-form input[type="email"]::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .newsletter-form input[type="email"]:focus {
        border-color: var(--color-primary);
    }

    .newsletter-form .btn-primary {
        padding: 0.85rem 2rem;
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .footer-bottom {
        padding-top: 2rem;
        text-align: center;
    }

    .copyright {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.85rem;
    }

    @media (max-width: 768px) {
        .footer-main {
            flex-direction: column;
            text-align: center;
            gap: 3rem;
        }

        .footer-brand {
            max-width: 100%;
        }

        .logo-container {
            justify-content: center;
        }

        .footer-links {
            flex-wrap: wrap;
            justify-content: center;
            gap: 2.5rem;
        }

        .footer-nav {
            align-items: center;
        }

        .newsletter-form {
            flex-direction: column;
        }

        .newsletter-form .btn-primary {
            width: 100%;
            justify-content: center;
        }
    }
</style>
