---
import Layout from '../layouts/Layout.astro';

// Latest Zeroed release — bump this single constant when a new version ships.
const LATEST_VERSION = '1.0.10';
const RELEASE_BASE = `https://github.com/stillware-ltd/zeroed-releases/releases/download/v${LATEST_VERSION}`;
const RELEASE_PAGE = `https://github.com/stillware-ltd/zeroed-releases/releases/tag/v${LATEST_VERSION}`;
---

<Layout
