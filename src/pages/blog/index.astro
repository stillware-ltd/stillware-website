---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredPosts = allPosts.filter(p => p.data.featured);
const regularPosts = allPosts.filter(p => !p.data.featured);

function readingTime(wordCount?: number): string {
  if (!wordCount) return '';
  return `${Math.ceil(wordCount / 238)} min read`;
}
---

<Layout
  title="Blog — Stillware Ltd"
  description="Thoughts on software ownership, privacy, and building tools that belong to you."
>
    <header class="blog-hero">
        <div class="container">
            <h1>Blog</h1>
            <p>Thoughts on software ownership, privacy, and the anti-SaaS movement.</p>
            <a href="/rss.xml" class="rss-link" aria-label="RSS Feed">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                RSS Feed
            </a>
        </div>
    </header>

    {featuredPosts.length > 0 && (
        <section class="featured-section">
            <div class="container">
                <h2 class="section-label">Featured</h2>
                <div class="featured-grid">
                    {featuredPosts.map(post => (
                        <a href={`/blog/${post.slug}`} class="featured-card reveal">
                            <span class="featured-badge">Featured</span>
                            <h3>{post.data.title}</h3>
                            <p>{post.data.description}</p>
                            <div class="featured-meta">
                                <time datetime={post.data.date.toISOString()}>
                                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                                </time>
                                {post.data.wordCount && (
                                    <span class="reading-time">{readingTime(post.data.wordCount)}</span>
                                )}
                            </div>
                            {post.data.tags && (
                                <div class="featured-tags">
                                    {post.data.tags.map(tag => (
                                        <span class="tag-pill tag-pill-featured">{tag}</span>
                                    ))}
                                </div>
                            )}
                        </a>
                    ))}
                </div>
            </div>
        </section>
    )}

    <section class="blog-list">
        <div class="container">
            {regularPosts.length === 0 && featuredPosts.length === 0 && (
                <div class="empty-state">
                    <p>No posts yet. Check back soon.</p>
                </div>
            )}
            {regularPosts.map((post, index) => (
                <>
                    {index === 4 && (
                        <div class="newsletter-cta reveal">
                            <h3>Join the Privacy-First Movement</h3>
                            <p>Get notified when we release new buy-once, offline-first software.</p>
                            <form name="newsletter" method="POST" data-netlify="true" action="/success" class="newsletter-cta-form">
                                <input type="hidden" name="form-name" value="newsletter" />
                                <input type="hidden" name="subject" value="New Newsletter Subscriber" />
                                <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
                                <button type="submit" class="btn-primary">Subscribe</button>
                            </form>
                        </div>
                    )}
                    <article class="post-card reveal">
                        <div class="post-meta">
                            <time datetime={post.data.date.toISOString()}>
                                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </time>
                            {post.data.wordCount && (
                                <span class="reading-time">{readingTime(post.data.wordCount)}</span>
                            )}
                        </div>
                        <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
                        {post.data.description && <p>{post.data.description}</p>}
                        {post.data.tags && (
                            <div class="post-tags">
                                {post.data.tags.map(tag => (
                                    <a href={`/blog/tag/${tag.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}`} class="tag-pill">{tag}</a>
                                ))}
                            </div>
                        )}
                        <a href={`/blog/${post.slug}`} class="read-more">Read more &rarr;</a>
                    </article>
                </>
            ))}
        </div>
    </section>
</Layout>

<style>
    .blog-hero {
        padding: 12rem 0 4rem;
        text-align: center;
        background: var(--gradient-obsidian);
    }

    .blog-hero h1 { font-size: 3.5rem; color: #ffffff; margin-bottom: 1rem; }
    .blog-hero p { font-size: 1.2rem; color: rgba(255, 255, 255, 0.65); margin-bottom: 1.5rem; }

    .rss-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s ease;
    }

    .rss-link:hover { color: #ffffff; }

    /* ── Featured Section ── */

    .featured-section {
        padding: 3rem 0 1rem;
        max-width: 750px;
        margin: 0 auto;
    }

    .section-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-primary);
        margin-bottom: 1.25rem;
    }

    .featured-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .featured-card {
        display: block;
        position: relative;
        background: var(--gradient-obsidian);
        border-radius: var(--border-radius);
        padding: 2rem;
        text-decoration: none;
        transition: transform 0.3s var(--transition-premium), box-shadow 0.3s ease;
        box-shadow: var(--shadow-md);
    }

    .featured-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-xl);
    }

    .featured-badge {
        display: inline-block;
        background: var(--color-primary);
        color: #ffffff;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.25rem 0.65rem;
        border-radius: 100px;
        margin-bottom: 1rem;
    }

    .featured-card h3 {
        color: #ffffff;
        font-size: 1.5rem;
        line-height: 1.3;
        margin-bottom: 0.75rem;
    }

    .featured-card p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .featured-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .featured-meta time {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .featured-meta .reading-time {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
    }

    .featured-meta .reading-time::before {
        content: "\00b7";
        margin-right: 0.75rem;
    }

    .featured-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tag-pill-featured {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.7rem;
        padding: 0.2rem 0.55rem;
        border-radius: 100px;
    }

    /* ── Blog List ── */

    .blog-list { padding: 3rem 0 8rem; max-width: 750px; margin: 0 auto; }

    .post-card {
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--color-border);
    }

    .post-card:first-child { padding-top: 0; }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .post-meta time {
        font-size: 0.85rem;
        color: var(--color-text-light);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .reading-time {
        font-size: 0.85rem;
        color: var(--color-text-light);
    }

    .reading-time::before {
        content: "\00b7";
        margin-right: 0.75rem;
    }

    .post-card h2 {
        font-size: 1.75rem;
        margin: 0 0 0.75rem;
        line-height: 1.3;
    }

    .post-card h2 a {
        color: var(--color-secondary);
        transition: color 0.2s ease;
    }

    .post-card h2 a:hover { color: var(--color-primary); }

    .post-card p {
        color: var(--color-text-light);
        line-height: 1.6;
        margin-bottom: 0.75rem;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.75rem;
    }

    .tag-pill {
        display: inline-block;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text-light);
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .tag-pill:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .read-more {
        color: var(--color-primary);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .read-more:hover { text-decoration: underline; }

    /* ── Newsletter CTA ── */

    .newsletter-cta {
        padding: 2.5rem;
        margin: 2rem 0;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        text-align: center;
    }

    .newsletter-cta h3 {
        font-size: 1.35rem;
        color: var(--color-secondary);
        margin-bottom: 0.5rem;
    }

    .newsletter-cta p {
        color: var(--color-text-light);
        font-size: 0.95rem;
        margin-bottom: 1.25rem;
    }

    .newsletter-cta-form {
        display: flex;
        gap: 0.75rem;
        max-width: 440px;
        margin: 0 auto;
    }

    .newsletter-cta-form input[type="email"] {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 1px solid var(--color-border);
        border-radius: 100px;
        font-size: 0.9rem;
        font-family: var(--font-sans);
        background: #ffffff;
        color: var(--color-secondary);
    }

    .newsletter-cta-form input[type="email"]::placeholder {
        color: var(--color-text-light);
    }

    .newsletter-cta-form input[type="email"]:focus {
        outline: none;
        border-color: var(--color-primary);
    }

    .newsletter-cta-form .btn-primary {
        padding: 0.75rem 1.5rem;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 0;
        color: var(--color-text-light);
    }

    @media (max-width: 768px) {
        .blog-hero h1 { font-size: 2.5rem; }

        .featured-grid {
            grid-template-columns: 1fr;
        }

        .newsletter-cta-form {
            flex-direction: column;
        }

        .newsletter-cta-form .btn-primary {
            width: 100%;
            justify-content: center;
        }
    }
</style>
