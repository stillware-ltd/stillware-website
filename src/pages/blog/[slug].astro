---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function readingTime(wordCount?: number): string {
  if (!wordCount) return '';
  return `${Math.ceil(wordCount / 238)} min read`;
}

// Resolve related posts
const allPosts = await getCollection('blog');
const relatedPosts = post.data.relatedSlugs
  ? post.data.relatedSlugs
      .map((slug: string) => allPosts.find(p => p.slug === slug))
      .filter(Boolean)
      .slice(0, 3)
  : [];

// Social sharing URLs
const shareUrl = new URL(`/blog/${post.slug}/`, Astro.site).href;
const shareTitle = encodeURIComponent(post.data.title);
const shareUrlEncoded = encodeURIComponent(shareUrl);

// Product CTA based on appCluster
const appCluster = post.data.appCluster || '';
const isZeroed = appCluster === 'zeroed' || post.data.tags?.some((t: string) => ['Personal Finance', 'Anti-SaaS', 'Comparison'].includes(t));
const isChess = appCluster === 'rankupchess' || post.data.tags?.some((t: string) => t.toLowerCase().includes('chess'));
---

<Layout
  title={`${post.data.title} — Stillware Ltd`}
  description={post.data.description}
  ogImage={post.data.heroImage || post.data.ogImage}
>
    <!-- BlogPosting Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.description || "",
        "datePublished": post.data.date.toISOString(),
        "author": {
            "@type": "Person",
            "name": post.data.author,
            "url": "https://www.stillwareltd.com"
        },
        "publisher": {
            "@type": "Organization",
            "name": "Stillware Ltd",
            "url": "https://www.stillwareltd.com",
            "logo": {
                "@type": "ImageObject",
                "url": "https://www.stillwareltd.com/logo.png"
            }
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": shareUrl
        },
        ...(post.data.heroImage ? { "image": new URL(post.data.heroImage, Astro.site).href } : {}),
        ...(post.data.wordCount ? { "wordCount": post.data.wordCount } : {}),
        ...(post.data.tags?.length ? { "keywords": post.data.tags.join(", ") } : {})
    })} />

    <article class="blog-post">
        <header class="post-hero">
            <div class="post-hero-inner">
                <div class="post-hero-meta">
                    <time datetime={post.data.date.toISOString()}>
                        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    {post.data.wordCount && (
                        <span class="post-reading-time">{readingTime(post.data.wordCount)}</span>
                    )}
                </div>
                <h1>{post.data.title}</h1>
                <p class="post-author">By {post.data.author}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-hero-tags">
                        {post.data.tags.map((tag: string) => (
                            <a href={`/blog/tag/${tag.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}`} class="hero-tag-pill">{tag}</a>
                        ))}
                    </div>
                )}
            </div>
        </header>

        {post.data.heroImage && (
            <div class="article-hero-image">
                <img src={post.data.heroImage} alt="" />
            </div>
        )}

        <div class="post-body">
            <Content />
        </div>

        <!-- Product CTA -->
        {isZeroed && (
            <div class="product-cta-banner">
                <div class="product-cta-inner">
                    <h3>Try Zeroed — The Budget App You Actually Own</h3>
                    <p>No servers. No subscriptions. Your data stays on your device, encrypted with AES-256. Try every feature free for 34 days.</p>
                    <div class="product-cta-actions">
                        <a href="/zeroed" class="btn-primary">Explore Zeroed</a>
                        <span class="product-cta-price">Founder's Seat: $19 (first 100 only)</span>
                    </div>
                </div>
            </div>
        )}
        {isChess && (
            <div class="product-cta-banner chess-cta-banner">
                <div class="product-cta-inner">
                    <h3>Try RankUpChess — The Offline Chess Academy for Kids</h3>
                    <p>5,000+ puzzles, 10-tier AI, interactive lessons. 100% offline. No subscriptions, no ads, no data harvesting.</p>
                    <div class="product-cta-actions">
                        <a href="/rankupchess" class="btn-primary chess-btn">Explore RankUpChess</a>
                    </div>
                </div>
            </div>
        )}

        <!-- Social Sharing -->
        <div class="share-bar">
            <div class="share-bar-inner">
                <span class="share-label">Share this article</span>
                <div class="share-buttons">
                    <a href={`https://twitter.com/intent/tweet?url=${shareUrlEncoded}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on X" title="Share on X">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on LinkedIn" title="Share on LinkedIn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <a href={`https://news.ycombinator.com/submitlink?u=${shareUrlEncoded}&t=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on Hacker News" title="Share on Hacker News">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 0v24h24V0H0zm12.4 13.4l-4-7.8h2l3 6 3-6h2l-4 7.8V20h-2v-6.6z"/></svg>
                    </a>
                    <button class="share-btn copy-url-btn" aria-label="Copy link" title="Copy link" data-url={shareUrl}>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                        <span class="copy-feedback">Copied!</span>
                    </button>
                </div>
            </div>
        </div>

        <aside class="author-card">
            <div class="author-card-inner">
                <div class="author-avatar">
                    {post.data.author === "Tejaswi Dhulipala" ? "TD" : "SW"}
                </div>
                <div class="author-info">
                    {post.data.author === "Tejaswi Dhulipala" ? (
                        <>
                            <p class="author-name">Written by Tejaswi Dhulipala</p>
                            <p class="author-bio">Founder & solo developer at Stillware Ltd, building local-first, privacy-respecting apps you own forever. No subscriptions, no telemetry.</p>
                        </>
                    ) : (
                        <>
                            <p class="author-name">Written by the Stillware Team</p>
                            <p class="author-bio">We build local-first, privacy-respecting software you own forever. No subscriptions, no cloud dependency, no data harvesting.</p>
                        </>
                    )}
                    <a href="/apps" class="author-link">Explore our apps &rarr;</a>
                </div>
            </div>
        </aside>

        <!-- Newsletter Signup -->
        <section class="newsletter-signup">
            <div class="newsletter-inner">
                <h2 class="newsletter-heading">The Stillware Letter</h2>
                <p class="newsletter-description">
                    A monthly essay on software ownership, privacy, and the anti-subscription movement.
                    No spam. No tracking. Unsubscribe anytime.
                </p>
                <form class="newsletter-form" name="newsletter-post" method="POST" data-netlify="true" action="/blog/">
                    <input type="hidden" name="form-name" value="newsletter-post" />
                    <input type="hidden" name="source" value={`/blog/${post.slug}/`} />
                    <input
                        type="email"
                        name="email"
                        placeholder="you@example.com"
                        required
                        autocomplete="email"
                        class="newsletter-input"
                    />
                    <button type="submit" class="newsletter-btn">Subscribe</button>
                </form>
                <p class="newsletter-privacy">We'll never share your email. That's kind of our whole thing.</p>
            </div>
        </section>

        <!-- Related Articles -->
        {relatedPosts.length > 0 && (
            <section class="related-posts">
                <div class="related-posts-inner">
                    <h2 class="related-heading">Up Next</h2>
                    <div class="related-grid">
                        {relatedPosts.map((related: any) => (
                            <a href={`/blog/${related.slug}`} class="related-card">
                                <time datetime={related.data.date.toISOString()}>
                                    {related.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </time>
                                {related.data.wordCount && (
                                    <span class="related-reading-time">{readingTime(related.data.wordCount)}</span>
                                )}
                                <h3>{related.data.title}</h3>
                                {related.data.description && (
                                    <p>{related.data.description.substring(0, 120)}{related.data.description.length > 120 ? '...' : ''}</p>
                                )}
                                <span class="related-link">Read more &rarr;</span>
                            </a>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <footer class="post-footer">
            <a href="/blog" class="btn-text">&larr; Back to Blog</a>
        </footer>
    </article>
</Layout>

<script>
    document.querySelectorAll('.copy-url-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const url = btn.getAttribute('data-url');
            if (url) {
                await navigator.clipboard.writeText(url);
                btn.classList.add('copied');
                setTimeout(() => btn.classList.remove('copied'), 2000);
            }
        });
    });
</script>

<style>
    .post-hero {
        padding: 12rem 2rem 4rem;
        text-align: center;
        background: var(--gradient-obsidian);
    }

    .post-hero-inner {
        max-width: 700px;
        margin: 0 auto;
    }

    .article-hero-image {
        max-width: 900px;
        margin: -4rem auto 2rem;
        padding: 0 2rem;
        position: relative;
        z-index: 10;
    }

    .article-hero-image img {
        width: 100%;
        height: auto;
        border-radius: 16px;
        box-shadow: var(--shadow-xl);
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: block;
    }

    .post-hero-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .post-hero-meta time {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-reading-time {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .post-reading-time::before {
        content: "\00b7";
        margin-right: 0.75rem;
    }

    .post-hero h1 {
        font-size: 3rem;
        color: #ffffff;
        margin: 0 0 0.75rem;
        line-height: 1.15;
    }

    .post-author {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .post-hero-tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.4rem;
    }

    .hero-tag-pill {
        display: inline-block;
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: rgba(255, 255, 255, 0.65);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .hero-tag-pill:hover {
        border-color: rgba(255, 255, 255, 0.5);
        color: rgba(255, 255, 255, 0.9);
    }

    .post-body {
        max-width: 740px;
        margin: 0 auto;
        padding: 3rem 2rem 4rem;
    }

    /* ── Headings ── */

    .post-body :global(h2) {
        font-size: 1.75rem;
        margin: 3rem 0 1rem;
        color: #0f172a;
        letter-spacing: -0.01em;
    }

    .post-body :global(h3) {
        font-size: 1.35rem;
        margin: 2.25rem 0 0.75rem;
        color: #1e293b;
    }

    /* ── Paragraphs & inline ── */

    .post-body :global(p) {
        font-size: 1.1rem;
        line-height: 1.85;
        color: #334155;
        margin-bottom: 1.35rem;
    }

    .post-body :global(strong) {
        color: #1e293b;
        font-weight: 600;
    }

    .post-body :global(a) {
        color: #2563eb;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(37, 99, 235, 0.3);
        transition: text-decoration-color 0.2s;
    }

    .post-body :global(a:hover) {
        text-decoration-color: #2563eb;
    }

    /* ── Lists ── */

    .post-body :global(ul), .post-body :global(ol) {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
    }

    .post-body :global(li) {
        font-size: 1.05rem;
        line-height: 1.75;
        color: #334155;
        margin-bottom: 0.6rem;
    }

    .post-body :global(li strong) {
        color: #1e293b;
    }

    /* ── Blockquotes ── */

    .post-body :global(blockquote) {
        border-left: 4px solid #2563eb;
        padding: 1.25rem 1.75rem;
        margin: 2rem 0;
        background: #f0f5ff;
        border-radius: 0 12px 12px 0;
        font-style: italic;
    }

    .post-body :global(blockquote p) {
        color: #475569;
        font-size: 1.05rem;
        margin-bottom: 0;
    }

    /* ── Code ── */

    .post-body :global(code) {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        color: #334155;
    }

    .post-body :global(pre) {
        background: #0f172a;
        color: #e2e8f0;
        padding: 1.5rem;
        border-radius: 12px;
        overflow-x: auto;
        margin: 2rem 0;
    }

    .post-body :global(pre code) {
        background: none;
        padding: 0;
        color: inherit;
    }

    /* ── Images ── */

    .post-body :global(img) {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
        margin: 2.5rem auto;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06);
    }

    /* ── Tables ── */

    .post-body :global(table) {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 2rem 0;
        font-size: 0.95rem;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.04);
    }

    .post-body :global(thead) {
        background: #2563eb;
    }

    .post-body :global(th) {
        padding: 0.85rem 1rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.9rem;
        color: #ffffff;
        letter-spacing: 0.01em;
        white-space: nowrap;
    }

    .post-body :global(td) {
        padding: 0.75rem 1rem;
        color: #334155;
        line-height: 1.5;
        border-top: 1px solid #e2e8f0;
        vertical-align: top;
    }

    .post-body :global(tbody tr:nth-child(even)) {
        background: #f8fafc;
    }

    .post-body :global(tbody tr:hover) {
        background: #f0f5ff;
        transition: background 0.15s;
    }

    .post-body :global(td strong) {
        color: #1e293b;
    }

    .post-body :global(td:first-child) {
        font-weight: 500;
        color: #1e293b;
    }

    /* ── Horizontal rules ── */

    .post-body :global(hr) {
        border: none;
        height: 1px;
        background: #e2e8f0;
        margin: 3rem 0;
    }

    /* ── CTA Box Styling (AI marketing tool output) ── */

    .post-body :global(.cta-box) {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-left: 4px solid var(--color-primary);
        border-radius: 0 var(--border-radius) var(--border-radius) 0;
        padding: 2rem;
        margin: 2.5rem 0;
        text-align: center;
    }

    .post-body :global(.cta-inline) {
        background: linear-gradient(135deg, #f0f5ff 0%, var(--color-surface) 100%);
        border: 1px solid var(--color-border);
        border-left: 4px solid var(--color-primary);
        border-radius: 0 var(--border-radius) var(--border-radius) 0;
        padding: 1.5rem 2rem;
        margin: 2rem 0;
        text-align: center;
    }

    .post-body :global(.cta-waitlist) {
        background: var(--gradient-obsidian);
        border: none;
        border-radius: var(--border-radius);
        padding: 2.5rem;
        margin: 2.5rem 0;
        text-align: center;
    }

    .post-body :global(.cta-waitlist p) {
        color: rgba(255, 255, 255, 0.7);
    }

    .post-body :global(.cta-button) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background-color: var(--color-primary);
        color: #ffffff;
        padding: 0.85rem 2rem;
        border-radius: 100px;
        font-weight: 600;
        font-size: 1rem;
        font-family: var(--font-sans);
        transition: all 0.3s var(--transition-premium);
        box-shadow: var(--shadow-md);
        text-decoration: none;
        border: none;
        cursor: pointer;
    }

    .post-body :global(.cta-button:hover) {
        background-color: var(--color-primary-dark);
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        color: #ffffff;
        text-decoration: none;
    }

    .post-body :global(.cta-waitlist .cta-button) {
        background-color: #ffffff;
        color: var(--color-secondary);
    }

    .post-body :global(.cta-waitlist .cta-button:hover) {
        background-color: #f0f5ff;
        color: var(--color-primary);
    }

    /* ── Product CTA Banner ── */

    .product-cta-banner {
        max-width: 740px;
        margin: 0 auto;
        padding: 0 2rem 2rem;
    }

    .product-cta-inner {
        background: linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #0F172A 100%);
        border-radius: 16px;
        padding: 2.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .product-cta-inner::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(37, 99, 235, 0.12) 0%, transparent 50%);
        pointer-events: none;
    }

    .product-cta-inner h3 {
        font-size: 1.4rem;
        color: #ffffff;
        margin: 0 0 0.75rem;
        position: relative;
    }

    .product-cta-inner p {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.6;
        margin: 0 0 1.5rem;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
        position: relative;
    }

    .product-cta-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        position: relative;
    }

    .product-cta-price {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 500;
    }

    .chess-cta-banner .product-cta-inner {
        background: linear-gradient(135deg, #451a03 0%, #78350f 50%, #451a03 100%);
    }

    .chess-cta-banner .product-cta-inner::before {
        background: radial-gradient(circle, rgba(245, 158, 11, 0.12) 0%, transparent 50%);
    }

    .chess-btn {
        background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%) !important;
        border-color: transparent !important;
    }

    .chess-btn:hover {
        background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%) !important;
    }

    /* ── Share Bar ── */

    .share-bar {
        max-width: 740px;
        margin: 0 auto;
        padding: 0 2rem 2rem;
    }

    .share-bar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
    }

    .share-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text-light);
    }

    .share-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .share-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: 1px solid var(--color-border);
        background: #ffffff;
        color: var(--color-text-light);
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        position: relative;
    }

    .share-btn:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
        background: #f0f5ff;
    }

    .copy-feedback {
        display: none;
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
