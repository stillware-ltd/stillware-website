---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} — Stillware Ltd`}
  description={post.data.description}
>
    <article class="blog-post">
        <header class="post-hero">
            <div class="post-hero-inner">
                <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h1>{post.data.title}</h1>
                <p class="post-author">By {post.data.author}</p>
            </div>
        </header>
        <div class="post-body">
            <Content />
        </div>
        <footer class="post-footer">
            <a href="/blog" class="btn-text">&larr; Back to Blog</a>
        </footer>
    </article>
</Layout>

<style>
    .post-hero {
        padding: 12rem 2rem 4rem;
        text-align: center;
        background: var(--gradient-obsidian);
    }

    .post-hero-inner {
        max-width: 700px;
        margin: 0 auto;
    }

    .post-hero time {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-hero h1 {
        font-size: 3rem;
        color: #ffffff;
        margin: 1rem 0 0.75rem;
        line-height: 1.15;
    }

    .post-author {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
    }

    .post-body {
        max-width: 740px;
        margin: 0 auto;
        padding: 3rem 2rem 4rem;
    }

    /* ── Headings ── */

    .post-body :global(h2) {
        font-size: 1.75rem;
        margin: 3rem 0 1rem;
        color: #0f172a;
        letter-spacing: -0.01em;
    }

    .post-body :global(h3) {
        font-size: 1.35rem;
        margin: 2.25rem 0 0.75rem;
        color: #1e293b;
    }

    /* ── Paragraphs & inline ── */

    .post-body :global(p) {
        font-size: 1.1rem;
        line-height: 1.85;
        color: #334155;
        margin-bottom: 1.35rem;
    }

    .post-body :global(strong) {
        color: #1e293b;
        font-weight: 600;
    }

    .post-body :global(a) {
        color: #2563eb;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(37, 99, 235, 0.3);
        transition: text-decoration-color 0.2s;
    }

    .post-body :global(a:hover) {
        text-decoration-color: #2563eb;
    }

    /* ── Lists ── */

    .post-body :global(ul), .post-body :global(ol) {
        margin: 1.5rem 0;
        padding-left: 1.5rem;
    }

    .post-body :global(li) {
        font-size: 1.05rem;
        line-height: 1.75;
        color: #334155;
        margin-bottom: 0.6rem;
    }

    .post-body :global(li strong) {
        color: #1e293b;
    }

    /* ── Blockquotes ── */

    .post-body :global(blockquote) {
        border-left: 4px solid #2563eb;
        padding: 1.25rem 1.75rem;
        margin: 2rem 0;
        background: #f0f5ff;
        border-radius: 0 12px 12px 0;
        font-style: italic;
    }

    .post-body :global(blockquote p) {
        color: #475569;
        font-size: 1.05rem;
        margin-bottom: 0;
    }

    /* ── Code ── */

    .post-body :global(code) {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        color: #334155;
    }

    .post-body :global(pre) {
        background: #0f172a;
        color: #e2e8f0;
        padding: 1.5rem;
        border-radius: 12px;
        overflow-x: auto;
        margin: 2rem 0;
    }

    .post-body :global(pre code) {
        background: none;
        padding: 0;
        color: inherit;
    }

    /* ── Images ── */

    .post-body :global(img) {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
        margin: 2.5rem auto;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06);
    }

    /* ── Tables ── */

    .post-body :global(table) {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 2rem 0;
        font-size: 0.95rem;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.04);
    }

    .post-body :global(thead) {
        background: #2563eb;
    }

    .post-body :global(th) {
        padding: 0.85rem 1rem;
        text-align: left;
        font-weight: 600;
        font-size: 0.9rem;
        color: #ffffff;
        letter-spacing: 0.01em;
        white-space: nowrap;
    }

    .post-body :global(td) {
        padding: 0.75rem 1rem;
        color: #334155;
        line-height: 1.5;
        border-top: 1px solid #e2e8f0;
        vertical-align: top;
    }

    .post-body :global(tbody tr:nth-child(even)) {
        background: #f8fafc;
    }

    .post-body :global(tbody tr:hover) {
        background: #f0f5ff;
        transition: background 0.15s;
    }

    .post-body :global(td strong) {
        color: #1e293b;
    }

    /* first column bold labels */
    .post-body :global(td:first-child) {
        font-weight: 500;
        color: #1e293b;
    }

    /* ── Horizontal rules ── */

    .post-body :global(hr) {
        border: none;
        height: 1px;
        background: #e2e8f0;
        margin: 3rem 0;
    }

    /* ── Footer ── */

    .post-footer {
        max-width: 740px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
        border-top: 1px solid #e2e8f0;
        padding-top: 2rem;
    }

    .post-footer :global(a) {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
    }

    .post-footer :global(a:hover) {
        text-decoration: underline;
    }

    /* ── Responsive ── */

    @media (max-width: 768px) {
        .post-hero h1 { font-size: 2.25rem; }

        .post-body :global(table) {
            display: block;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .post-body :global(img) {
            border-radius: 8px;
            margin: 1.5rem auto;
        }
    }
</style>
