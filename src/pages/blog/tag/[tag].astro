---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

function tagSlug(tag: string): string {
  return tag.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // Collect all unique tags
  const tagMap = new Map<string, { slug: string; name: string }>();
  for (const post of posts) {
    if (post.data.tags) {
      for (const tag of post.data.tags) {
        const slug = tag.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
        if (!tagMap.has(slug)) {
          tagMap.set(slug, { slug, name: tag });
        }
      }
    }
  }

  return Array.from(tagMap.values()).map(({ slug, name }) => ({
    params: { tag: slug },
    props: { tagName: name, tagSlug: slug },
  }));
}

const { tagName, tagSlug: currentTagSlug } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const filteredPosts = allPosts.filter(post =>
  post.data.tags?.some(t => t.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-') === currentTagSlug)
);

function readingTime(wordCount?: number): string {
  if (!wordCount) return '';
  return `${Math.ceil(wordCount / 238)} min read`;
}
---

<Layout
  title={`${tagName} — Stillware Ltd Blog`}
  description={`Articles about ${tagName}. Thoughts on software ownership, privacy, and the anti-SaaS movement.`}
>
    <header class="tag-hero">
        <div class="container">
            <a href="/blog" class="back-link">&larr; All Posts</a>
            <h1>{tagName}</h1>
            <p>{filteredPosts.length} article{filteredPosts.length !== 1 ? 's' : ''}</p>
        </div>
    </header>

    <section class="blog-list">
        <div class="container">
            {filteredPosts.map(post => (
                <article class="post-card reveal">
                    <div class="post-meta">
                        <time datetime={post.data.date.toISOString()}>
                            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                        </time>
                        {post.data.wordCount && (
                            <span class="reading-time">{readingTime(post.data.wordCount)}</span>
                        )}
                    </div>
                    <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
                    {post.data.description && <p>{post.data.description}</p>}
                    {post.data.tags && (
                        <div class="post-tags">
                            {post.data.tags.map(tag => {
                                const slug = tag.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
                                return (
                                    <a
                                        href={`/blog/tag/${slug}`}
                                        class:list={["tag-pill", { "tag-pill-active": slug === currentTagSlug }]}
                                    >
                                        {tag}
                                    </a>
                                );
                            })}
                        </div>
                    )}
                    <a href={`/blog/${post.slug}`} class="read-more">Read more &rarr;</a>
                </article>
            ))}
        </div>
    </section>
</Layout>

<style>
    .tag-hero {
        padding: 12rem 0 3rem;
        text-align: center;
        background: var(--gradient-obsidian);
    }

    .back-link {
        display: inline-block;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 1rem;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .back-link:hover { color: #ffffff; }

    .tag-hero h1 { font-size: 3rem; color: #ffffff; margin-bottom: 0.5rem; }
    .tag-hero p { font-size: 1.1rem; color: rgba(255, 255, 255, 0.5); }

    .blog-list { padding: 3rem 0 8rem; max-width: 750px; margin: 0 auto; }

    .post-card {
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--color-border);
    }

    .post-card:first-child { padding-top: 0; }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .post-meta time {
        font-size: 0.85rem;
        color: var(--color-text-light);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .reading-time {
        font-size: 0.85rem;
        color: var(--color-text-light);
    }

    .reading-time::before {
        content: "\00b7";
        margin-right: 0.75rem;
    }

    .post-card h2 {
        font-size: 1.75rem;
        margin: 0 0 0.75rem;
        line-height: 1.3;
    }

    .post-card h2 a {
        color: var(--color-secondary);
        transition: color 0.2s ease;
    }

    .post-card h2 a:hover { color: var(--color-primary); }

    .post-card p {
        color: var(--color-text-light);
        line-height: 1.6;
        margin-bottom: 0.75rem;
    }

    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.75rem;
    }

    .tag-pill {
        display: inline-block;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text-light);
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .tag-pill:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .tag-pill-active {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: #ffffff;
    }

    .tag-pill-active:hover {
        color: #ffffff;
    }

    .read-more {
        color: var(--color-primary);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .read-more:hover { text-decoration: underline; }

    @media (max-width: 768px) {
        .tag-hero h1 { font-size: 2.25rem; }
    }
</style>
