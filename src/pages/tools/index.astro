---
import Layout from '../../layouts/Layout.astro';

const frictionlessTools = [
  {
    title: 'True Hourly Wage Calculator',
    slug: 'true-hourly-wage-calculator',
    description: 'Find out what you really earn per hour after commuting, overtime, and hidden work costs. The number might surprise you.',
    icon: '&#128176;',
    tag: 'Calculator',
  },
  {
    title: 'SaaS vs. Ownership Simulator',
    slug: 'saas-vs-ownership-simulator',
    description: 'See exactly how much you spend renting software over 1, 3, and 5 years versus buying it once.',
    icon: '&#128200;',
    tag: 'Simulator',
  },
];

const gatedTools = [
  {
    title: 'Chess Tournament Packing List',
    slug: 'chess-tournament-packing-list',
    description: 'The complete, printable checklist every chess parent needs the night before a tournament. Never forget the clock again.',
    icon: '&#9822;',
    tag: 'Printable PDF',
  },
  {
    title: 'Chess Vision Offline Puzzles',
    slug: 'chess-vision-offline-puzzles',
    description: '50 hand-picked tactical puzzles your child can solve with zero screen time. Print, fold, play.',
    icon: '&#9823;',
    tag: 'Printable PDF',
  },
  {
    title: 'Cash Envelope Ledger Sheets',
    slug: 'cash-envelope-ledgers',
    description: 'Beautiful, printable ledger sheets for every budget envelope. Track spending by hand — the way that actually sticks.',
    icon: '&#9993;',
    tag: 'Printable PDF',
  },
];
---

<Layout
  title="Free Tools & Resources — Stillware Ltd"
  description="Free calculators, simulators, and printable resources for budgeting, chess parents, and anyone tired of renting software."
>
  <header class="tools-hero">
    <div class="container">
      <h1>Free Tools & Resources</h1>
      <p>Calculators you can use instantly. Printables you'll actually keep. No sign-up required for calculators — just answers.</p>
    </div>
  </header>

  <section class="tools-section">
    <div class="container">
      <div class="section-header">
        <h2>Instant Calculators</h2>
        <p class="section-subtitle">Use them right now. No email. No sign-up. Just results.</p>
      </div>
      <div class="tools-grid">
        {frictionlessTools.map(tool => (
          <a href={`/tools/${tool.slug}`} class="tool-card reveal">
            <span class="tool-tag">{tool.tag}</span>
            <div class="tool-icon" set:html={tool.icon} />
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
            <span class="tool-cta">Use Now &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="tools-section">
    <div class="container">
      <div class="section-header">
        <h2>Printable Resources</h2>
        <p class="section-subtitle">High-quality PDFs sent straight to your inbox. Print them as many times as you like.</p>
      </div>
      <div class="tools-grid three-col">
        {gatedTools.map(tool => (
          <a href={`/tools/${tool.slug}`} class="tool-card gated reveal">
            <span class="tool-tag gated-tag">{tool.tag}</span>
            <div class="tool-icon" set:html={tool.icon} />
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
            <span class="tool-cta">Get Free PDF &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .tools-hero {
    padding: 12rem 0 4rem;
    text-align: center;
    background: var(--gradient-obsidian);
  }

  .tools-hero h1 {
    font-size: 3.5rem;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .tools-hero p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.65);
    max-width: 600px;
    margin: 0 auto;
  }

  .tools-section {
    padding: 5rem 0;
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-subtitle {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-top: 0.75rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .tools-grid.three-col {
    grid-template-columns: repeat(3, 1fr);
  }

  .tool-card {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    transition: all 0.4s var(--transition-premium);
    box-shadow: var(--shadow-premium);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    border-color: rgba(37, 99, 235, 0.2);
    box-shadow: var(--shadow-xl);
  }

  .tool-card.gated:hover {
    border-color: rgba(245, 158, 11, 0.3);
  }

  .tool-tag {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(37, 99, 235, 0.08);
    color: var(--color-primary);
    width: fit-content;
    margin-bottom: 1.25rem;
  }

  .tool-tag.gated-tag {
    background: rgba(245, 158, 11, 0.1);
    color: #B45309;
  }

  .tool-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .tool-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    color: var(--color-secondary);
  }

  .tool-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }

  .tool-cta {
    display: inline-block;
    margin-top: 1.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
    transition: transform 0.2s ease;
  }

  .tool-card:hover .tool-cta {
    transform: translateX(4px);
  }

  .tool-card.gated .tool-cta {
    color: #B45309;
  }

  @media (max-width: 1024px) {
    .tools-grid.three-col {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .tools-hero h1 { font-size: 2.5rem; }
    .tools-grid,
    .tools-grid.three-col {
      grid-template-columns: 1fr;
    }
  }
</style>
