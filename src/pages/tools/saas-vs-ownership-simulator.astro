---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="SaaS vs. Buy-Once Software Calculator — How Much Are Subscriptions Costing You? | Stillware Ltd"
  description="Compare the real cost of renting software subscriptions versus buying once. See your 1-year, 3-year, and 5-year totals. Free calculator — no sign-up."
>
  <header class="tool-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/tools">Tools</a> <span>/</span> <span>SaaS vs. Ownership Simulator</span>
      </nav>
      <h1>SaaS vs. Ownership Simulator</h1>
      <p>You're probably spending more on subscriptions than you think. Add your apps below and watch the numbers stack up.</p>
    </div>
  </header>

  <section class="calculator-section">
    <div class="container">
      <div class="calculator-layout">
        <div class="calc-form">
          <p class="form-intro">Add each subscription you currently pay for. We'll show you the true cost over time.</p>

          <div id="sub-list">
            <div class="sub-row">
              <input type="text" class="sub-name" placeholder="App name (e.g. YNAB)" />
              <div class="input-prefix">
                <span class="prefix">&pound;</span>
                <input type="number" class="sub-cost" placeholder="6.99" min="0" step="0.01" />
              </div>
              <select class="sub-period">
                <option value="monthly">/ month</option>
                <option value="yearly">/ year</option>
              </select>
            </div>
          </div>

          <button type="button" id="add-row" class="btn-add">+ Add Another Subscription</button>

          <div class="form-group" style="margin-top: 2rem;">
            <label for="buy-once">One-Time Purchase Alternative</label>
            <p class="field-hint">What would a buy-once replacement cost? (e.g. Zeroed at &pound;19.99)</p>
            <div class="input-prefix">
              <span class="prefix">&pound;</span>
              <input type="number" id="buy-once" placeholder="19.99" value="19.99" min="0" step="0.01" />
            </div>
          </div>

          <button type="button" id="simulate-btn" class="btn-primary calc-btn">Show Me the Damage</button>
        </div>

        <div id="results" class="results-panel" style="display:none;">
          <h2 class="results-title">The Subscription Tax</h2>

          <div class="timeline-grid">
            <div class="timeline-card">
              <span class="timeline-label">1 Year</span>
              <div class="timeline-row">
                <span>Subscriptions</span>
                <strong class="cost-sub" id="sub-1yr">&pound;0</strong>
              </div>
              <div class="timeline-row own-row">
                <span>Buy Once</span>
                <strong class="cost-own" id="own-1yr">&pound;0</strong>
              </div>
              <div class="timeline-savings">
                You save <strong id="save-1yr">&pound;0</strong>
              </div>
            </div>

            <div class="timeline-card featured">
              <span class="timeline-label">3 Years</span>
              <div class="timeline-row">
                <span>Subscriptions</span>
                <strong class="cost-sub" id="sub-3yr">&pound;0</strong>
              </div>
              <div class="timeline-row own-row">
                <span>Buy Once</span>
                <strong class="cost-own" id="own-3yr">&pound;0</strong>
              </div>
              <div class="timeline-savings">
                You save <strong id="save-3yr">&pound;0</strong>
              </div>
            </div>

            <div class="timeline-card">
              <span class="timeline-label">5 Years</span>
              <div class="timeline-row">
                <span>Subscriptions</span>
                <strong class="cost-sub" id="sub-5yr">&pound;0</strong>
              </div>
              <div class="timeline-row own-row">
                <span>Buy Once</span>
                <strong class="cost-own" id="own-5yr">&pound;0</strong>
              </div>
              <div class="timeline-savings">
                You save <strong id="save-5yr">&pound;0</strong>
              </div>
            </div>
          </div>

          <div class="bar-visual">
            <div class="bar-group">
              <span class="bar-label">Subscriptions (5yr)</span>
              <div class="bar bar-sub" id="bar-sub"></div>
              <span class="bar-amount" id="bar-sub-amount">&pound;0</span>
            </div>
            <div class="bar-group">
              <span class="bar-label">Buy Once</span>
              <div class="bar bar-own" id="bar-own"></div>
              <span class="bar-amount" id="bar-own-amount">&pound;0</span>
            </div>
          </div>

          <div class="cta-banner">
            <h3>Stop Renting Your Software</h3>
            <p>Buy Zeroed once. Budget forever. 100% offline, AES-256 encrypted, no subscriptions.</p>
            <a href="/zeroed" class="btn-primary pulse">Get Zeroed — &pound;19.99 for Life</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  function createRow(): string {
    return `<div class="sub-row">
      <input type="text" class="sub-name" placeholder="App name" />
      <div class="input-prefix">
        <span class="prefix">£</span>
        <input type="number" class="sub-cost" placeholder="9.99" min="0" step="0.01" />
      </div>
      <select class="sub-period">
        <option value="monthly">/ month</option>
        <option value="yearly">/ year</option>
      </select>
      <button type="button" class="remove-row" aria-label="Remove">&times;</button>
    </div>`;
  }

  document.getElementById('add-row')!.addEventListener('click', () => {
    const list = document.getElementById('sub-list')!;
    list.insertAdjacentHTML('beforeend', createRow());
  });

  document.getElementById('sub-list')!.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-row')) {
      target.closest('.sub-row')?.remove();
    }
  });

  document.getElementById('simulate-btn')!.addEventListener('click', () => {
    const rows = document.querySelectorAll('.sub-row');
    let annualTotal = 0;

    rows.forEach(row => {
      const cost = parseFloat((row.querySelector('.sub-cost') as HTMLInputElement).value) || 0;
      const period = (row.querySelector('.sub-period') as HTMLSelectElement).value;
      annualTotal += period === 'monthly' ? cost * 12 : cost;
    });

    const buyOnce = parseFloat((document.getElementById('buy-once') as HTMLInputElement).value) || 0;

    const fmt = (n: number) => `£${n.toFixed(2)}`;

    [1, 3, 5].forEach(years => {
      const subTotal = annualTotal * years;
      const saving = subTotal - buyOnce;
      document.getElementById(`sub-${years}yr`)!.textContent = fmt(subTotal);
      document.getElementById(`own-${years}yr`)!.textContent = fmt(buyOnce);
      document.getElementById(`save-${years}yr`)!.textContent = fmt(Math.max(0, saving));
    });

    const sub5 = annualTotal * 5;
    const maxVal = Math.max(sub5, buyOnce, 1);
    (document.getElementById('bar-sub') as HTMLElement).style.width = `${(sub5 / maxVal) * 100}%`;
    (document.getElementById('bar-own') as HTMLElement).style.width = `${(buyOnce / maxVal) * 100}%`;
    document.getElementById('bar-sub-amount')!.textContent = fmt(sub5);
    document.getElementById('bar-own-amount')!.textContent = fmt(buyOnce);

    document.getElementById('results')!.style.display = 'block';
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

<style>
  .tool-hero {
    padding: 12rem 0 4rem;
    background: var(--gradient-obsidian);
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: #ffffff; }
  .breadcrumb span { color: rgba(255, 255, 255, 0.3); margin: 0 0.5rem; }
  .breadcrumb span:last-child { color: rgba(255, 255, 255, 0.7); margin: 0; }

  .tool-hero h1 {
    font-size: 3rem;
    color: #ffffff;
    margin-bottom: 1rem;
    max-width: 700px;
  }

  .tool-hero p {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    line-height: 1.6;
  }

  .calculator-section {
    padding: 4rem 0 8rem;
  }

  .calculator-layout {
    max-width: 720px;
    margin: 0 auto;
  }

  .calc-form {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: var(--shadow-premium);
  }

  .form-intro {
    color: var(--color-text-light);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .sub-row {
    display: grid;
    grid-template-columns: 1fr 120px 120px auto;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }

  .sub-row input[type="text"],
  .sub-row input[type="number"],
  .sub-row select {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    outline: none;
    background: var(--color-surface);
    transition: border-color 0.2s;
  }

  .sub-row input:focus,
  .sub-row select:focus {
    border-color: var(--color-primary);
    background: #ffffff;
  }

  .input-prefix {
    position: relative;
  }

  .input-prefix .prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-light);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .input-prefix input {
    padding-left: 2rem !important;
  }

  .remove-row {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--color-text-light);
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    transition: color 0.2s;
  }

  .remove-row:hover { color: #DC2626; }

  .btn-add {
    background: none;
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    padding: 0.75rem;
    width: 100%;
    color: var(--color-text-light);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.5rem;
  }

  .btn-add:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(37, 99, 235, 0.03);
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }

  .field-hint {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .form-group input[type="number"] {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    background: var(--color-surface);
    transition: border-color 0.2s;
  }

  .form-group input[type="number"]:focus {
    border-color: var(--color-primary);
    background: #ffffff;
  }

  .calc-btn {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  /* Results */
  .results-panel {
    margin-top: 3rem;
  }

  .results-title {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .timeline-card {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
  }

  .timeline-card.featured {
    border-color: rgba(37, 99, 235, 0.3);
    background: rgba(37, 99, 235, 0.02);
    transform: scale(1.03);
  }

  .timeline-label {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .timeline-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .cost-sub { color: #DC2626; }
  .cost-own { color: #059669; }

  .timeline-savings {
    border-top: 1px solid var(--color-border);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    font-size: 0.85rem;
    color: #059669;
    font-weight: 600;
  }

  .timeline-savings strong { color: #059669; }

  .bar-visual {
    margin-bottom: 3rem;
  }

  .bar-group {
    margin-bottom: 1rem;
  }

  .bar-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .bar {
    height: 36px;
    border-radius: 8px;
    min-width: 4px;
    transition: width 0.8s var(--transition-premium);
  }

  .bar-sub { background: linear-gradient(90deg, #EF4444, #DC2626); }
  .bar-own { background: linear-gradient(90deg, #10B981, #059669); }

  .bar-amount {
    font-size: 0.9rem;
    font-weight: 700;
    margin-top: 0.25rem;
    display: inline-block;
  }

  .cta-banner {
    margin-top: 3rem;
    background: var(--gradient-obsidian);
    border-radius: 20px;
    padding: 3rem;
    text-align: center;
  }

  .cta-banner h3 {
    color: #ffffff;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .cta-banner p {
    color: rgba(255, 255, 255, 0.65);
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .tool-hero h1 { font-size: 2.25rem; }
    .calc-form { padding: 1.75rem; }
    .sub-row {
      grid-template-columns: 1fr;
    }
    .timeline-grid {
      grid-template-columns: 1fr;
    }
    .timeline-card.featured {
      transform: none;
    }
    .cta-banner { padding: 2rem 1.5rem; }
    .cta-banner h3 { font-size: 1.4rem; }
  }
</style>
