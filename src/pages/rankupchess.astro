---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="RankUpChess — The Offline Chess Academy for Kids"
  description="A premium, 100% offline chess academy designed for kids. No subscriptions, no internet required, no data harvesting. Pay once, own forever."
  canonical="https://www.stillwareltd.com/rankupchess"
>
    <!-- Hero -->
    <header class="chess-hero">
        <div class="hero-ambient" aria-hidden="true"></div>
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="text-gradient-gold">Stop renting your kids' educational apps.</h1>
                <p class="subheadline">Welcome to <strong>RankUpChess</strong>. A premium, 100% offline chess academy designed for kids. No monthly subscriptions, no internet required, and absolutely no data harvesting. Just pure chess.</p>
                <div class="hero-cta">
                    <a href="#pricing" class="btn-primary pulse">
                        Download Free Trial
                    </a>
                    <div class="platform-badges">
                        <span class="platform-badge">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" /></svg>
                            Windows
                        </span>
                        <span class="platform-badge coming-soon">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" /></svg>
                            App Store — Soon
                        </span>
                        <span class="platform-badge coming-soon">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.523 2.293l-1.59 2.755c-1.17-.678-2.53-1.048-3.933-1.048s-2.763.37-3.933 1.048L6.477 2.293a.578.578 0 00-.79.211.58.58 0 00.211.79l1.548 2.682A8.502 8.502 0 004 12.5h16a8.502 8.502 0 00-3.446-6.524l1.548-2.682a.58.58 0 00-.579-.79zM9 10.5a1 1 0 110-2 1 1 0 010 2zm6 0a1 1 0 110-2 1 1 0 010 2zM4 13.5v6a2.5 2.5 0 005 0v-6zm11 0v6a2.5 2.5 0 005 0v-6z" /></svg>
                            Google Play — Soon
                        </span>
                    </div>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-carousel">
                    <img src="/rankupchess-screens/RankUpChess_Screen_1.png" alt="RankUpChess — Home Screen" class="hero-image hero-slide active" width="600" height="400" />
                    <img src="/rankupchess-screens/RankUpChess_Screen_10.png" alt="RankUpChess — Match View" class="hero-image hero-slide" width="600" height="400" loading="lazy" />
                    <img src="/rankupchess-screens/RankUpChess_Screen_6.png" alt="RankUpChess — Puzzle Library" class="hero-image hero-slide" width="600" height="400" loading="lazy" />
                </div>
            </div>
        </div>
    </header>

    <!-- The Stillware Difference -->
    <section class="difference-section reveal" id="difference">
        <div class="container">
            <div class="section-header center-text">
                <h2 class="text-gradient-gold">The Subscription Trap is Over.</h2>
            </div>
            <div class="difference-content reveal-up reveal-delay-1">
                <p class="difference-lead">Most modern kids' apps are built to drain your wallet with <strong>$50/year subscriptions</strong> while secretly harvesting your child's data in the cloud.</p>
                <p>We built RankUpChess to be the ultimate subscription-free alternative to legacy chess giants. Every feature is designed to help your child master the game — from absolute beginner to tournament ready — while keeping them in a completely closed, <strong>100% offline environment</strong>. Zero stress. Total control.</p>
            </div>
        </div>
    </section>

    <!-- App Slides -->
    <section class="slides-section reveal" id="app-slides">
        <div class="container">
            <div class="section-header center-text">
                <h2>See RankUpChess in Action.</h2>
                <p class="slides-sub">A full chess academy, running entirely on your device.</p>
            </div>
            <div class="slides-ui-wrapper reveal-up reveal-delay-1">
                <button class="slide-nav-btn prev" aria-label="Previous Slide">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                </button>
                <div class="slides-container-wrapper">
                    <div class="slides-container">
                        <img src="/rankupchess-screens/RankUpChess_Screen_2.png" alt="RankUpChess — AI Difficulty Levels" class="slide-image" width="360" height="640" loading="lazy" />
                        <img src="/rankupchess-screens/RankUpChess_Screen_3.png" alt="RankUpChess — Chess Match" class="slide-image" width="360" height="640" loading="lazy" />
                        <img src="/rankupchess-screens/RankUpChess_Screen_7.png" alt="RankUpChess — Skill Tree" class="slide-image" width="360" height="640" loading="lazy" />
                        <img src="/rankupchess-screens/RankUpChess_Screen_6.png" alt="RankUpChess — Puzzle Library" class="slide-image" width="360" height="640" loading="lazy" />
                        <img src="/rankupchess-screens/RankUpChess_Screen_8.png" alt="RankUpChess — Home with Daily Challenge" class="slide-image" width="360" height="640" loading="lazy" />
                    </div>
                </div>
                <button class="slide-nav-btn next" aria-label="Next Slide">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                </button>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="features-section reveal" id="features">
        <div class="container">
            <div class="section-header center-text">
                <h2>Everything They Need.<br />Nothing They Don't.</h2>
            </div>
            <div class="features-grid">
                <div class="feature-card reveal-up reveal-delay-1">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <h3>Pay Once, Own Forever</h3>
                    <p>Stop paying endless monthly fees just to let your child play chess. RankUpChess offers a lifetime license for just $7.99. You own the software, forever.</p>
                </div>
                <div class="feature-card reveal-up reveal-delay-2">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    <h3>The "Fort Knox" Privacy Architecture</h3>
                    <p>100% offline, local-first gameplay. We have no central servers, no chat rooms, and literally cannot track your child. The safest digital environment possible.</p>
                </div>
                <div class="feature-card reveal-up reveal-delay-3">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    </div>
                    <h3>5,000+ Tactical Puzzles</h3>
                    <p>A massive, built-in library of brain-teasing puzzles. From simple mate-in-ones to advanced middle-game strategies, your child will never run out of challenges.</p>
                </div>
                <div class="feature-card reveal-up reveal-delay-4">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                    </div>
                    <h3>10-Tier AI Engine</h3>
                    <p>Practice against an adaptive AI. Start at Level 1 (Beginner — 400 Elo) and work up to Level 10 (World Class — 3200 Elo) as your child's skills grow.</p>
                </div>
                <div class="feature-card reveal-up reveal-delay-1">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    </div>
                    <h3>The "Zero-Friction" Learn Module</h3>
                    <p>An interactive, completely distraction-free learning environment. Master piece movements, castling, and advanced tactics without needing an internet connection.</p>
                </div>
                <div class="feature-card reveal-up reveal-delay-2">
                    <div class="icon-box">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
                    </div>
                    <h3>Advanced Coach's Dashboard</h3>
                    <p>Review past games with instant replays and track concrete metrics to measure your child's improvement over time.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Parental Controls -->
    <section class="parental-section reveal" id="parental">
        <div class="container">
            <div class="parental-grid">
                <div class="parental-text">
                    <h2>Built for Kids,<br />Controlled by Parents.</h2>
                    <p class="parental-headline">Total Peace of Mind.</p>
                    <p>We built RankUpChess with a strict <strong>Parental Gate</strong> system. Kids can launch the app and jump into a game in seconds with zero friction. Meanwhile, sensitive settings, profile resets, and the premium upgrade screen are locked safely behind a parental pin.</p>
                    <p class="parental-reassure">Let them learn, play, and make mistakes — without worrying about what they might click on.</p>
                </div>
                <div class="parental-visual">
                    <img src="/rankupchess-screens/RankUpChess_Screen_9.png" alt="RankUpChess — AI Difficulty Selection with Parental Controls" class="parental-image" width="600" height="400" loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section class="pricing-section reveal" id="pricing">
        <div class="container">
            <div class="pricing-header">
                <h2>Try it Risk-Free.</h2>
                <p class="pricing-sub">RankUpChess is completely free to download. Your child can try the Learn module, play the introductory AI levels, and solve a starter pack of daily puzzles to experience the app risk-free.</p>
            </div>
            <div class="pricing-card featured">
                <div class="badge-pill">One-Time Purchase</div>
                <h3>Unlock Their Full Potential</h3>
                <p class="pricing-desc">A single, one-time purchase unlocks the entire suite — 5,000+ puzzles, advanced AI, and deep analytics. We will never charge you a recurring subscription.</p>
                <div class="price-container">
                    <span class="price-amount">$7.99</span>
                    <span class="price-label">One-time. Forever.</span>
                </div>
                <ul class="features-list">
                    <li><span class="check-icon">&#10003;</span> 5,000+ Tactical Puzzles</li>
                    <li><span class="check-icon">&#10003;</span> All 10 AI Difficulty Levels</li>
                    <li><span class="check-icon">&#10003;</span> Full Learn Module & Skill Tree</li>
                    <li><span class="check-icon">&#10003;</span> Advanced Coach's Dashboard</li>
                    <li><span class="check-icon">&#10003;</span> All Future Updates Included</li>
                </ul>
                <a href="#" class="btn-primary pulse pricing-cta">Start Your Chess Journey Today</a>
                <p class="pricing-note">Free trial included. No credit card required.</p>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta-section">
        <div class="final-cta-content">
            <img src="/RankUpChess_logo.png" alt="RankUpChess" class="final-logo" width="120" height="120" />
            <h2>The Chess Academy They Deserve.</h2>
            <p>No subscriptions. No data harvesting. No internet required. Just pure, premium chess education — owned by you, forever.</p>
            <a href="#pricing" class="btn-primary pulse">Download RankUpChess</a>
        </div>
    </section>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Hero Carousel
        const heroSlides = document.querySelectorAll('.hero-slide');
        let heroIndex = 0;
        if (heroSlides.length > 1) {
            setInterval(() => {
                heroSlides[heroIndex].classList.remove('active');
                heroIndex = (heroIndex + 1) % heroSlides.length;
                heroSlides[heroIndex].classList.add('active');
            }, 4000);
        }

        // App Slides Carousel
        const slidesContainer = document.querySelector('.slides-container');
        const prevBtn = document.querySelector('.slide-nav-btn.prev');
        const nextBtn = document.querySelector('.slide-nav-btn.next');

        if (slidesContainer && prevBtn && nextBtn) {
            const slideWidth = () => {
                const slide = slidesContainer.querySelector('.slide-image');
                if (!slide) return 300;
                return slide.offsetWidth + 20;
            };

            prevBtn.addEventListener('click', () => {
                slidesContainer.scrollBy({ left: -slideWidth(), behavior: 'smooth' });
            });

            nextBtn.addEventListener('click', () => {
                slidesContainer.scrollBy({ left: slideWidth(), behavior: 'smooth' });
            });

            let autoAdvance = setInterval(() => {
                const maxScroll = slidesContainer.scrollWidth - slidesContainer.clientWidth;
                if (slidesContainer.scrollLeft >= maxScroll - 10) {
                    slidesContainer.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    slidesContainer.scrollBy({ left: slideWidth(), behavior: 'smooth' });
                }
            }, 5000);

            slidesContainer.addEventListener('mouseenter', () => clearInterval(autoAdvance));
            slidesContainer.addEventListener('mouseleave', () => {
                autoAdvance = setInterval(() => {
                    const maxScroll = slidesContainer.scrollWidth - slidesContainer.clientWidth;
                    if (slidesContainer.scrollLeft >= maxScroll - 10) {
                        slidesContainer.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        slidesContainer.scrollBy({ left: slideWidth(), behavior: 'smooth' });
                    }
                }, 5000);
            });
        }
    });
</script>

<style>
    /* Gold Gradient Text */
    .text-gradient-gold {
        background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 50%, #F59E0B 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Hero */
    .chess-hero {
        position: relative;
        overflow: hidden;
        padding: 10rem 0 6rem;
        background:
            radial-gradient(ellipse 900px 700px at 50% 40%, rgba(245, 158, 11, 0.07) 0%, transparent 70%),
            radial-gradient(ellipse 600px 600px at 85% 20%, rgba(251, 191, 36, 0.05) 0%, transparent 60%),
            var(--gradient-obsidian);
    }

    .hero-ambient {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 0;
    }

    .hero-ambient::before {
        content: '';
        position: absolute;
        top: -200px;
        left: -100px;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.1) 0%, transparent 70%);
        filter: blur(60px);
        animation: float-orb-1 20s ease-in-out infinite;
    }

    .hero-ambient::after {
        content: '';
        position: absolute;
        bottom: -150px;
        right: -50px;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(251, 191, 36, 0.06) 0%, transparent 70%);
        filter: blur(80px);
        animation: float-orb-2 25s ease-in-out infinite;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .hero-text h1 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        letter-spacing: -0.04em;
        line-height: 1.1;
    }

    .subheadline {
        font-size: 1.15rem;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: 2rem;
        line-height: 1.7;
    }

    .subheadline strong {
        color: #FBBF24;
    }

    .hero-cta {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .hero-cta .btn-primary {
        align-self: flex-start;
        background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
        border-color: transparent;
    }

    .hero-cta .btn-primary:hover {
        background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
    }

    .platform-badges {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .platform-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.12);
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .platform-badge svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .platform-badge.coming-soon {
        opacity: 0.5;
    }

    /* Hero Carousel */
    .hero-visual {
        position: relative;
    }

    .hero-carousel {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    }

    .hero-slide {
        width: 100%;
        display: block;
        opacity: 0;
        position: absolute;
        top: 0;
        left: 0;
        transition: opacity 0.8s ease-in-out;
        border-radius: 20px;
    }

    .hero-slide.active {
        opacity: 1;
        position: relative;
    }

    /* Difference Section */
    .difference-section {
        padding: 6rem 0;
        background: var(--color-surface);
    }

    .difference-content {
        max-width: 780px;
        margin: 2rem auto 0;
        text-align: center;
    }

    .difference-lead {
        font-size: 1.25rem;
        color: var(--color-text);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .difference-content p {
        font-size: 1.1rem;
        color: var(--color-text-light);
        line-height: 1.7;
    }

    .difference-content strong {
        color: var(--color-secondary);
    }

    /* Slides Section */
    .slides-section {
        padding: 6rem 0;
    }

    .slides-sub {
        color: var(--color-text-light);
        font-size: 1.1rem;
        margin-top: 0.75rem;
    }

    .slides-ui-wrapper {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 3rem;
    }

    .slide-nav-btn {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--color-border);
        background: #ffffff;
        color: var(--color-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-premium);
    }

    .slide-nav-btn:hover {
        background: var(--color-surface);
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .slides-container-wrapper {
        overflow: hidden;
        flex: 1;
        border-radius: 16px;
    }

    .slides-container {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 1rem 0;
    }

    .slides-container::-webkit-scrollbar {
        display: none;
    }

    .slide-image {
        flex-shrink: 0;
        width: 280px;
        height: auto;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        scroll-snap-align: start;
        transition: transform 0.3s ease;
    }

    .slide-image:hover {
        transform: scale(1.02);
    }

    /* Features */
    .features-section {
        padding: 6rem 0;
        background: var(--color-surface);
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 3rem;
    }

    .feature-card {
        background: #ffffff;
        padding: 2.5rem;
        border-radius: 20px;
        border: 1px solid rgba(226, 232, 240, 0.6);
        transition: all 0.4s var(--transition-premium);
        box-shadow: var(--shadow-premium);
        position: relative;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
        border-radius: 20px 20px 0 0;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 24px rgba(245, 158, 11, 0.08);
        border-color: rgba(245, 158, 11, 0.15);
    }

    .feature-card:hover::before {
        opacity: 1;
    }

    .icon-box {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
        color: #D97706;
        margin-bottom: 1.25rem;
        transition: all 0.4s var(--transition-premium);
    }

    .feature-card:hover .icon-box {
        transform: scale(1.1) rotate(3deg);
        background: linear-gradient(135deg, #FEF3C7, #FDE68A);
        box-shadow: 0 4px 16px rgba(245, 158, 11, 0.2);
    }

    .feature-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.75rem;
        color: var(--color-secondary);
    }

    .feature-card p {
        color: var(--color-text-light);
        font-size: 1rem;
        line-height: 1.6;
    }

    /* Parental Section */
    .parental-section {
        padding: 8rem 0;
    }

